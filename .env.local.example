# PostgreSQL connection string for the development database
DATABASE_URL=postgresql://user:password@localhost:5432/niticore_dev

# 64-char hex string for encrypting internal auth TOTP secrets — generate with: openssl rand -hex 32
INTERNAL_AUTH_ENCRYPTION_KEY=<64-char hex string — generate with: openssl rand -hex 32>

# Secret used to sign and verify internal JWT tokens (any random string for development)
INTERNAL_AUTH_JWT_SECRET=<any random string for development>

# How long a magic link is valid (in minutes)
MAGIC_LINK_EXPIRY_MINUTES=10

# How long a temp JWT (issued before TOTP) is valid (in minutes)
TEMP_JWT_EXPIRY_MINUTES=5

# Rate limiting: time window in milliseconds
RATE_LIMIT_WINDOW_MS=60000

# Rate limiting: max requests per window
RATE_LIMIT_MAX_REQUESTS=5

# Email sender address for magic links and notifications
EMAIL_FROM=noreply@niticore.com

# Base URL for magic link verification (used in emails sent to users)
MAGIC_LINK_BASE_URL=http://localhost:3000/internal/auth/verify

# Application environment (development, test, production)
NODE_ENV=development
